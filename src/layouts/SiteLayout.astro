---
import SiteFooter from "../components/SiteFooter.astro";
import SiteHeader from "../components/SiteHeader.astro";
import type { Language } from "../data/content";
import BaseLayout from "./BaseLayout.astro";

interface Props {
  alternatePath: string;
  canonicalPath: string;
  currentPage: "contact" | "home" | "international" | "media" | "privacy";
  description: string;
  language: Language;
  markdownMirror?: boolean;
  structuredData?: object | object[];
  title: string;
}

const props = Astro.props;
---

<BaseLayout
  title={props.title}
  description={props.description}
  canonicalPath={props.canonicalPath}
  alternatePath={props.alternatePath}
  language={props.language}
  markdownMirror={props.markdownMirror}
  structuredData={props.structuredData}
>
  <a class="skip-link" href="#main">
    {props.language === "ja" ? "本文へ移動" : "Skip to content"}
  </a>
  <SiteHeader language={props.language} currentPage={props.currentPage} />
  <slot />
  <SiteFooter language={props.language} />
</BaseLayout>
