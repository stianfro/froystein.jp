---
import { certifications, type Language } from "../data/content";
import BlogPostList from "./BlogPostList.astro";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const isJapanese = language === "ja";
const mediaPath = isJapanese ? "/ja/media/" : "/media/";
const contactPath = isJapanese ? "/ja/contact/" : "/contact/";
---

<main id="main" class="home-page page-shell">
  <section class="home-hero">
    <div class="hero-copy">
      <p class="eyebrow">KUBERNETES / CLOUD NATIVE / SRE</p>
      <h1 class="factual-title">
        {
          isJapanese ? (
            <>
              <>
                <span>Kubernetes・</span>
                <span>クラウドネイティブ</span>
                <span>コンサルティング</span>
              </>
            </>
          ) : (
            <>
              <>
                <span>Kubernetes and</span>
                <span>Cloud Native</span>
                <span>Consultancy</span>
              </>
            </>
          )
        }
      </h1>
      <p class="lead">
        {
          isJapanese
            ? "株式会社フロイスタインコンサルティングは、Kubernetesとクラウドネイティブ技術に関するコンサルティングを提供しています。"
            : "Froystein Consulting provides consultancy services for Kubernetes and cloud native technology."
        }
      </p>
      <p>
        <a class="text-link" href={contactPath}>
          {
            isJapanese
              ? "技術相談について問い合わせる"
              : "Enquire about technical consultancy"
          }
        </a>
      </p>
    </div>
    <dl class="fact-list">
      <div>
        <dt>{isJapanese ? "拠点" : "Location"}</dt><dd>
          {isJapanese ? "東京" : "Tokyo"}
        </dd>
      </div>
      <div>
        <dt>{isJapanese ? "対応言語" : "Languages"}</dt><dd>
          日本語 / English / Norsk
        </dd>
      </div>
      <div><dt>{isJapanese ? "設立" : "Established"}</dt><dd>2021</dd></div>
    </dl>
  </section>

  <section class="media-entry">
    <div class="section-heading">
      <p class="section-code">PROFILE</p>
      <h2>{isJapanese ? "プロフィール・取材" : "About and media"}</h2>
    </div>
    <div>
      <p class="section-intro">
        {
          isJapanese
            ? "東京在住のノルウェー人として、日本語・英語でのテレビ出演、取材、番組リサーチに対応します。"
            : "As a Norwegian living in Tokyo, Stian is available for television, interviews, and programme research in Japanese or English."
        }
      </p>
      <a class="text-link" href={mediaPath}>
        {
          isJapanese
            ? "プロフィールとテレビ出演歴を見る"
            : "View profile and TV appearances"
        }
      </a>
    </div>
  </section>

  <section class="content-section" aria-labelledby="blog-posts-heading">
    <div class="section-heading">
      <p class="section-code">WRITING</p>
      <h2 id="blog-posts-heading">Blog posts</h2>
    </div>
    <div>
      <BlogPostList language={language} />
      <p class="section-link">
        <a
          class="text-link"
          href="https://blog.froystein.jp/en/"
          rel="noopener noreferrer"
          target="_blank"
        >
          {
            isJapanese
              ? "blog.froystein.jp の記事一覧"
              : "All posts on blog.froystein.jp"
          }
        </a>
      </p>
    </div>
  </section>

  <section class="content-section" aria-labelledby="certifications-heading">
    <div class="section-heading">
      <p class="section-code">CERTIFICATIONS</p>
      <h2 id="certifications-heading">
        {isJapanese ? "認定資格" : "Certifications"}
      </h2>
    </div>
    <ul class="plain-link-list">
      {
        certifications.map((certification) => (
          <li>
            <a
              href={certification.url}
              rel="noopener noreferrer"
              target="_blank"
            >
              {certification.title}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</main>
