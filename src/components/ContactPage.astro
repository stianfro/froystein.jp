---
import type { Language } from "../data/content";

interface Props {
  language: Language;
}
const { language } = Astro.props;
const isJapanese = language === "ja";
---

<main id="main" class="contact-page page-shell">
  <header class="contact-hero">
    <p class="eyebrow">CONTACT</p>
    <h1>{isJapanese ? "お問い合わせ" : "Contact"}</h1>
    <p class="lead">
      {
        isJapanese
          ? "ご相談内容に応じて、以下の窓口からお問い合わせください。"
          : "Choose the type of enquiry below."
      }
    </p>
  </header>
  <div class="contact-options">
    <section>
      <p class="section-code">CONSULTING</p>
      <h2>{isJapanese ? "技術コンサルティング" : "Technical consultancy"}</h2>
      <p>
        {
          isJapanese
            ? "Kubernetes、クラウドネイティブ、プラットフォームエンジニアリング、SREに関するご相談は、LinkedInからご連絡ください。"
            : "For Kubernetes, cloud native, platform engineering, or SRE enquiries, contact Stian through LinkedIn."
        }
      </p>
      <a
        class="contact-action"
        href="https://www.linkedin.com/in/stian-fr%C3%B8ystein-1baa52103"
        rel="noopener noreferrer"
        target="_blank"
        data-umami-event="consultancy_linkedin_click"
        data-umami-event-language={language}
        data-umami-event-page="contact"
        >{isJapanese ? "LinkedInで問い合わせる" : "Contact via LinkedIn"}</a
      >
    </section>
    <section>
      <p class="section-code">INTERNATIONAL / MEDIA</p>
      <h2>
        {
          isJapanese
            ? "国際業務・取材のご相談"
            : "International services and media"
        }
      </h2>
      <p>
        {
          isJapanese
            ? "ご相談内容、希望時期、対応形式（対面・出張・オンライン）、必要な言語、返信期限をメールでお知らせください。"
            : "Please email the request, preferred timing and format, required language direction, and your reply deadline."
        }
      </p>
      <a
        class="contact-action"
        href="mailto:contact@froystein.jp"
        data-umami-event="international_email_click"
        data-umami-event-language={language}
        data-umami-event-page="contact"
        >{
          isJapanese
            ? "contact@froystein.jp にメール"
            : "Email contact@froystein.jp"
        }</a
      >
      <p class="contact-note">
        {
          isJapanese
            ? "内容を確認し、対応可能な場合に折り返しご連絡します。"
            : "We will review the details and reply when we can assist."
        }
      </p>
    </section>
  </div>
</main>
