---
import type { Language } from "../data/content";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const isJapanese = language === "ja";
---

<main id="main" class="consultancy-page page-shell">
  <section class="consultancy-hero">
    <div class="hero-copy">
      <p class="eyebrow">TECHNICAL CONSULTANCY</p>
      <h1>
        {
          isJapanese
            ? "Kubernetes・クラウドネイティブ"
            : "Kubernetes and cloud native"
        }
      </h1>
      <p class="lead">
        {
          isJapanese
            ? "株式会社フロイスタインコンサルティングは、Kubernetesとクラウドネイティブ技術に関するコンサルティングを提供しています。"
            : "Froystein Consulting provides consultancy services for Kubernetes and cloud native technology."
        }
      </p>
    </div>
    <dl class="consultancy-brief">
      <div>
        <dt>{isJapanese ? "拠点" : "Location"}</dt>
        <dd>{isJapanese ? "東京" : "Tokyo"}</dd>
      </div>
      <div>
        <dt>{isJapanese ? "対応言語" : "Languages"}</dt>
        <dd>日本語 / English / Norsk</dd>
      </div>
      <div>
        <dt>{isJapanese ? "技術経験" : "Technical experience"}</dt>
        <dd>{isJapanese ? "2015年から" : "Since 2015"}</dd>
      </div>
    </dl>
  </section>

  <section class="content-grid">
    <div class="section-heading">
      <p class="section-code">AREAS</p>
      <h2>{isJapanese ? "対応分野" : "Areas"}</h2>
    </div>
    <ul>
      <li>Kubernetes</li>
      <li>
        {isJapanese ? "クラウドネイティブ技術" : "Cloud native technology"}
      </li>
      <li>
        {
          isJapanese
            ? "プラットフォームエンジニアリング"
            : "Platform engineering"
        }
      </li>
      <li>SRE</li>
    </ul>
  </section>

  <section class="consultancy-contact">
    <div>
      <p class="section-code">CONTACT</p>
      <h2>{isJapanese ? "お問い合わせ" : "Contact"}</h2>
    </div>
    <div>
      <p>
        {
          isJapanese
            ? "技術コンサルティングに関するご相談は、LinkedInからご連絡ください。"
            : "For technical consultancy enquiries, contact Stian through LinkedIn."
        }
      </p>
      <a
        class="contact-action"
        href="https://www.linkedin.com/in/stian-fr%C3%B8ystein-1baa52103"
        rel="noopener noreferrer"
        target="_blank"
        data-umami-event="consultancy_linkedin_click"
        data-umami-event-language={language}
        data-umami-event-page="consulting"
      >
        {isJapanese ? "LinkedInで問い合わせる" : "Contact via LinkedIn"}
      </a>
    </div>
  </section>
</main>
