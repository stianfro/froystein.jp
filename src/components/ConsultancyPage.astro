---
import {
  certifications,
  consultancyAreas,
  consultancySteps,
  type Language,
} from "../data/content";
import BlogPostList from "./BlogPostList.astro";

interface Props {
  language: Language;
}

const { language } = Astro.props;
const isJapanese = language === "ja";
const contactPath = isJapanese ? "/ja/contact/" : "/contact/";
const mediaPath = isJapanese ? "/ja/media/" : "/media/";
---

<main id="main" class="consultancy-page page-shell">
  <section class="consultancy-hero">
    <div class="hero-copy">
      <p class="eyebrow">KUBERNETES / PLATFORM ENGINEERING / SRE</p>
      <h1 class="consultancy-title">
        {
          isJapanese ? (
            <>
              <span>運用できる</span>
              <span>Kubernetes</span>
              <span>プラットフォームへ</span>
            </>
          ) : (
            <>
              <span>Kubernetes consulting</span>
              <span>for platforms that</span>
              <span>have to work</span>
            </>
          )
        }
      </h1>
      <p class="lead">
        {
          isJapanese
            ? "株式会社フロイスタインコンサルティングは、Kubernetesプラットフォームの設計、レビュー、運用改善を支援します。Linux、クラウド基盤、Kubernetes、SREにおける2015年からの実務経験に基づいて対応します。"
            : "Froystein Consulting helps teams design, review, and improve the operation of Kubernetes platforms. Advice is grounded in professional experience across Linux, cloud infrastructure, Kubernetes, and SRE since 2015."
        }
      </p>
      <a class="contact-action" href={contactPath}>
        {
          isJapanese
            ? "技術相談について問い合わせる"
            : "Discuss a platform problem"
        }
      </a>
    </div>
    <dl class="consultancy-brief">
      <div>
        <dt>{isJapanese ? "拠点" : "Based"}</dt>
        <dd>{isJapanese ? "東京" : "Tokyo, Japan"}</dd>
      </div>
      <div>
        <dt>{isJapanese ? "対応言語" : "Languages"}</dt>
        <dd>
          {
            isJapanese
              ? "日本語・英語・ノルウェー語"
              : "English, Japanese, Norwegian"
          }
        </dd>
      </div>
      <div>
        <dt>{isJapanese ? "技術経験" : "Experience"}</dt>
        <dd>{isJapanese ? "2015年から" : "Since 2015"}</dd>
      </div>
      <div>
        <dt>{isJapanese ? "対象" : "Focus"}</dt>
        <dd>Kubernetes / Platform Engineering / SRE</dd>
      </div>
    </dl>
  </section>

  <section class="content-grid consultancy-signals">
    <div class="section-heading">
      <p class="section-code">WHEN TO REVIEW</p>
      <h2>{isJapanese ? "ご相談の例" : "When a review helps"}</h2>
    </div>
    <ul class="signal-list">
      <li>
        {
          isJapanese
            ? "新しいKubernetesプラットフォームの境界や設計判断を、実装前に確認したい"
            : "A new Kubernetes platform needs clear boundaries and an independent architecture review before implementation."
        }
      </li>
      <li>
        {
          isJapanese
            ? "クラスタのアップグレードや大きな設計変更に伴うリスクを整理したい"
            : "Cluster upgrades or major design changes carry risks that need to be understood and sequenced."
        }
      </li>
      <li>
        {
          isJapanese
            ? "インフラ、プラットフォーム、アプリケーションチーム間の責任範囲が曖昧になっている"
            : "Ownership is unclear across infrastructure, platform, and application teams."
        }
      </li>
      <li>
        {
          isJapanese
            ? "開発チーム向けのセルフサービスと、運用上必要なガードレールを両立したい"
            : "Application teams need useful self-service paths without losing the guardrails required for reliable operation."
        }
      </li>
    </ul>
  </section>

  <section class="content-grid consultancy-areas">
    <div class="section-heading">
      <p class="section-code">AREAS</p>
      <h2>{isJapanese ? "対応分野" : "Consulting areas"}</h2>
    </div>
    <div class="area-list">
      {
        consultancyAreas.map((area) => (
          <article>
            <h3>{area.title[language]}</h3>
            <p>{area.summary[language]}</p>
            <ul>
              {area.topics[language].map((topic) => (
                <li>{topic}</li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </section>

  <section class="content-grid consultancy-process">
    <div class="section-heading">
      <p class="section-code">WORKING MODEL</p>
      <h2>{isJapanese ? "進め方" : "How the work proceeds"}</h2>
    </div>
    <ol class="process-list">
      {
        consultancySteps.map((step, index) => (
          <li>
            <span class="process-number">
              {String(index + 1).padStart(2, "0")}
            </span>
            <div>
              <h3>{step.title[language]}</h3>
              <p>{step.detail[language]}</p>
            </div>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="content-grid consultancy-evidence">
    <div class="section-heading">
      <p class="section-code">PUBLIC WORK</p>
      <h2>
        {isJapanese ? "公開している技術記事" : "Technical work in public"}
      </h2>
    </div>
    <div>
      <p class="section-intro">
        {
          isJapanese
            ? "設計判断、Kubernetesの高可用性、Gateway API、コンテナレジストリ、開発環境について執筆しています。"
            : "Published work covers platform architecture, Kubernetes high availability, Gateway API, container registries, and development environments."
        }
      </p>
      <BlogPostList language={language} />
    </div>
  </section>

  <section class="content-grid consultancy-credentials">
    <div class="section-heading">
      <p class="section-code">EXPERIENCE</p>
      <h2>
        {isJapanese ? "担当者と認定資格" : "Practitioner and credentials"}
      </h2>
    </div>
    <div class="credentials-grid">
      <div>
        <h3>Stian Frøystein</h3>
        <p class="alternate-name">
          Stian Froeystein / スティアン・フロイスタイン
        </p>
        <p>
          {
            isJapanese
              ? "株式会社フロイスタインコンサルティング代表取締役、Intility AS Lead Site Reliability Engineer。Linux、クラウド基盤、Kubernetes、SREに約11年の実務経験があります。"
              : "Representative Director of Froystein Consulting Co., Ltd and Lead Site Reliability Engineer at Intility AS, with about 11 years of professional experience across Linux, cloud infrastructure, Kubernetes, and SRE."
          }
        </p>
        <a class="text-link" href={mediaPath}>
          {isJapanese ? "プロフィールを見る" : "View full profile"}
        </a>
      </div>
      <ul class="plain-link-list">
        {
          certifications.map((certification) => (
            <li>
              <a
                href={certification.url}
                rel="noopener noreferrer"
                target="_blank"
              >
                {certification.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </section>

  <section class="consultancy-contact">
    <div>
      <p class="section-code">CONTACT</p>
      <h2>{isJapanese ? "技術相談" : "Technical consultancy"}</h2>
    </div>
    <div>
      <p>
        {
          isJapanese
            ? "現在の構成、困っている点、判断が必要な時期をお知らせください。内容を確認し、対応可能な場合にご連絡します。"
            : "Share the current setup, the problem to solve, and when a decision is needed. I will review the context and reply when I can assist."
        }
      </p>
      <a
        class="contact-action"
        href="https://www.linkedin.com/in/stian-fr%C3%B8ystein-1baa52103"
        rel="noopener noreferrer"
        target="_blank"
        data-umami-event="consultancy_linkedin_click"
        data-umami-event-language={language}
        data-umami-event-page="consulting"
      >
        {isJapanese ? "LinkedInで問い合わせる" : "Contact via LinkedIn"}
      </a>
    </div>
  </section>
</main>
