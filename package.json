{
  "name": "froystein-jp",
  "private": true,
  "version": "1.5.0",
  "type": "module",
  "packageManager": "bun@1.3.14",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 astro build",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "lint": "ASTRO_TELEMETRY_DISABLED=1 astro check && prettier --check astro.config.mjs prettier.config.mjs package.json tsconfig.json \"src/**/*.{astro,css,ts}\" \"tests/**/*.ts\"",
    "format": "prettier --write astro.config.mjs prettier.config.mjs package.json tsconfig.json \"src/**/*.{astro,css,ts}\" \"tests/**/*.ts\"",
    "test": "bun test"
  },
  "dependencies": {
    "@astrojs/sitemap": "3.7.3",
    "@ibm/plex-sans-jp": "3.0.0",
    "astro": "7.0.7"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@types/bun": "^1.3.14",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "typescript": "5.9.2"
  }
}
